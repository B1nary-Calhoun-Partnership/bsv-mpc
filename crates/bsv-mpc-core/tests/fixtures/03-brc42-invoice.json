        "key_id_raw": " AbC123 ",
        "shared_secret_hex": "0279be667ef9dcbbac55a06295ce870b07029bfcdb2dce28d959f2815b16f81798",
        "shared_secret_source": "secp256k1 G compressed (test-only pin)"
      },
      "intermediate": {
        "normalized_protocol_id": "auth message signature",
        "invoice_string": "2-auth message signature- AbC123 ",
        "invoice_bytes_hex": "322d61757468206d657373616765207369676e61747572652d2041624331323320",
        "invoice_length_bytes": 33
      },
      "expected": {
        "hmac_offset_hex": "52ca69e463fa1b2abeabc7be3739aa45cd591f816fb003bb315ac487b23bdf91"
      }
    },
    {
      "name": "brc42-stress-vector-2-unicode-rejected",
      "spec_ref": "§03.5.2",
      "inputs": {
        "security_level": 2,
        "protocol_id_raw": "Café Société",
        "key_id_raw": "Δοκιμή"
      },
      "expected": {
        "rejected": true,
        "reason": "protocol name must match /^[a-z0-9 ]+$/ after .toLowerCase().trim() (canonical @bsv SDK computeInvoiceNumber); Unicode letters are not permitted"
      }
    },
    {
      "name": "brc42-stress-vector-3-empty-key-id-rejected",
      "spec_ref": "§03.5.3",
      "inputs": {
        "security_level": 2,
        "protocol_id_raw": "test",
        "key_id_raw": ""
      },
      "expected": {
        "rejected": true,
        "reason": "key_id length must be 1..=800 (canonical @bsv SDK computeInvoiceNumber throws when keyID.length < 1)"
      }
    },
    {
      "name": "brc42-stress-vector-4-protocol-too-short-rejected",
      "spec_ref": "§03.2.1",
      "inputs": {
        "security_level": 2,
        "protocol_id_raw": "abcd",
        "key_id_raw": "1"
      },
      "expected": {
        "rejected": true,
        "reason": "normalized protocol name must be >= 5 chars (SDK: 'Protocol names must be 5 characters or more')"
      }
    },
    {
      "name": "brc42-stress-vector-5-consecutive-spaces-rejected",
      "spec_ref": "§03.2.1",
      "inputs": {
        "security_level": 2,
        "protocol_id_raw": "auth  message",
        "key_id_raw": "1"
      },
      "expected": {
        "rejected": true,
        "reason": "normalized protocol name must not contain consecutive spaces (SDK: 'cannot contain multiple consecutive spaces')"
      }
    },
    {
      "name": "brc42-stress-vector-6-trailing-protocol-rejected",
      "spec_ref": "§03.2.1",
      "inputs": {
        "security_level": 2,
        "protocol_id_raw": "my cool protocol",
        "key_id_raw": "1"
      },
      "expected": {
        "rejected": true,
        "reason": "normalized protocol name must not end with ' protocol' (SDK: 'No need to end your protocol name with \" protocol\"')"
      }
    }
  ],
  "stress_vector_notes": "Vector 1 is a valid ASCII mixed-case/whitespace canonicalization case with a test-only pinned shared_secret (secp256k1 G compressed). Vectors 2-6 are REJECTION cases (corrected 2026-05-21): they pin inputs the canonical @bsv SDK KeyDeriver.computeInvoiceNumber rejects (Unicode protocol name; empty key_id; protocol < 5 chars; consecutive spaces; trailing ' protocol'). Implementations MUST reject them per §03.2.1 BEFORE any HMAC. bsv-mpc conforms (validate_protocol_name / validate_key_id); rust-mpc build_invoice_number MUST add this validation."
}
