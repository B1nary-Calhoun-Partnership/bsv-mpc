{
  "name": "bsv-mpc-container-probe",
  "main": "worker.js",
  "compatibility_date": "2025-05-01",
  "containers": [
    {
      "class_name": "BsvMpcContainer",
      "image": "./Dockerfile",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [
      { "class_name": "BsvMpcContainer", "name": "BSV_MPC_CONTAINER" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["BsvMpcContainer"] }
  ]
}
